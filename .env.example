# Google Maps Platform — Street View, Directions, and Places (same key; enable all three APIs)
GOOGLE_STREET_VIEW_API_KEY=

# Hugging Face Inference API for storefront captioning (do not commit real keys)
HUGGINGFACE_API_KEY=

# Cursor SDK — opportunity brief agent (do not commit real keys)
# Get one at https://cursor.com/dashboard/integrations
CURSOR_API_KEY=

# Optional: GitHub repo URL for cloud Cursor agents on Vercel
GITHUB_REPO_URL=https://github.com/yutuf/cursorHackathon
